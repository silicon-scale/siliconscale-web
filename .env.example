## Copy to `.env.local` (do not commit real values)
#
# EmailJS (client-side)
# These are public identifiers, but treat them as config, not secrets.
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# Neon Postgres (via Vercel Neon integration — auto-injected in production)
DATABASE_URL=
# POSTGRES_URL=  # alternate name from some Neon integrations

# Vercel Blob (via Vercel Blob integration — auto-injected in production)
BLOB_READ_WRITE_TOKEN=

# Blog admin auth (Phase 2 login — set in Vercel dashboard, never commit)
ADMIN_PASSWORD=
# Optional: separate signing secret for session cookies (falls back to ADMIN_PASSWORD)
SESSION_SECRET=

