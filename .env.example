## Copy to `.env` (do not commit real values)
#
# EmailJS (client-side)
# These are public identifiers, but treat them as config, not secrets.
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# ---------------------------------------------------------------------------
# Neon Postgres (Vercel Neon integration injects these in production)
# Prefer DATABASE_URL (pooled) for serverless API routes.
# ---------------------------------------------------------------------------
DATABASE_URL=
DATABASE_URL_UNPOOLED=
POSTGRES_URL=
POSTGRES_URL_NON_POOLING=
POSTGRES_PRISMA_URL=
POSTGRES_URL_NO_SSL=
POSTGRES_USER=
POSTGRES_HOST=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=
PGHOST=
PGHOST_UNPOOLED=
PGUSER=
PGDATABASE=
PGPASSWORD=

# ---------------------------------------------------------------------------
# Vercel Blob (Vercel Blob integration injects these in production)
# ---------------------------------------------------------------------------
BLOB_READ_WRITE_TOKEN=
BLOB_STORE_ID=

# ---------------------------------------------------------------------------
# Blog admin auth (set locally + in Vercel dashboard — never commit)
# ---------------------------------------------------------------------------
ADMIN_PASSWORD=
# Optional: separate signing secret for session cookies (falls back to ADMIN_PASSWORD)
SESSION_SECRET=

# ---------------------------------------------------------------------------
# Public site origin for canonical URLs, Open Graph, and sitemap.xml
# Defaults to https://siliconscale.dev when unset
# ---------------------------------------------------------------------------
SITE_URL=https://siliconscale.dev
